rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDocPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function userRole(uid) {
      return get(userDocPath(uid)).data.role;
    }

    function isAdvocate() {
      return signedIn()
        && exists(userDocPath(request.auth.uid))
        && userRole(request.auth.uid) == 'advocate';
    }

    function isAdmin() {
      return signedIn()
        && exists(userDocPath(request.auth.uid))
        && userRole(request.auth.uid) == 'admin';
    }

    function ownsAdvocateRecord(advocateId) {
      return isAdvocate() && request.auth.uid == advocateId;
    }

    function accessDocPath(token) {
      return /databases/$(database)/documents/client_access/$(token);
    }

    function accessDocExists(token) {
      return exists(accessDocPath(token));
    }

    function accessDocData(token) {
      return get(accessDocPath(token)).data;
    }

    function accessOpen(token) {
      return accessDocExists(token)
        && accessDocData(token).enabled == true
        && accessDocData(token).status != 'Closed';
    }

    function ownsAccessToken(token) {
      return accessDocExists(token)
        && ownsAdvocateRecord(accessDocData(token).advocate_id);
    }

    match /users/{userId} {
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == userId
        && request.resource.data.role in ['admin', 'advocate'];

      allow read: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'name',
          'phone',
          'officeAddress',
          'address',
          'enrollmentNumber',
          'email',
          'profilePicUrl',
          'preferredLanguage',
          'profileComplete'
        ]);
    }

    match /cases/{caseId} {
      allow create: if ownsAdvocateRecord(request.resource.data.advocate_id);
      allow read, update, delete: if ownsAdvocateRecord(resource.data.advocate_id);
    }

    match /clients/{clientId} {
      allow read, update, delete: if ownsAdvocateRecord(resource.data.advocate_id);
      allow create: if ownsAdvocateRecord(request.resource.data.advocate_id);
    }

    match /hearings/{hearingId} {
      allow read, update, delete: if ownsAdvocateRecord(resource.data.advocate_id);
      allow create: if ownsAdvocateRecord(request.resource.data.advocate_id);
    }

    match /payments/{paymentId} {
      allow read, update, delete: if ownsAdvocateRecord(resource.data.advocate_id);
      allow create: if ownsAdvocateRecord(request.resource.data.advocate_id);
    }

    match /documents/{documentId} {
      allow read, update, delete: if ownsAdvocateRecord(resource.data.advocate_id);
      allow create: if ownsAdvocateRecord(request.resource.data.advocate_id);
    }

    match /comments/{commentId} {
      allow read, update, delete: if ownsAdvocateRecord(resource.data.advocate_id);
      allow create: if ownsAdvocateRecord(request.resource.data.advocate_id);
    }

    match /drafting_sessions/{sessionId} {
      allow read, update, delete: if ownsAdvocateRecord(resource.data.advocate_id);
      allow create: if ownsAdvocateRecord(request.resource.data.advocate_id);
    }

    match /drafting_sources/{sourceId} {
      allow read, update, delete: if ownsAdvocateRecord(resource.data.advocate_id);
      allow create: if ownsAdvocateRecord(request.resource.data.advocate_id);
    }

    match /drafting_outputs/{outputId} {
      allow read, update, delete: if ownsAdvocateRecord(resource.data.advocate_id);
      allow create: if ownsAdvocateRecord(request.resource.data.advocate_id);
    }

    match /client_access/{token} {
      allow read: if accessOpen(token) || ownsAccessToken(token);
      allow update, delete: if ownsAccessToken(token);
      allow create: if ownsAdvocateRecord(request.resource.data.advocate_id);

      match /payments/{paymentId} {
        allow read: if accessOpen(token) || ownsAccessToken(token);

        allow create: if ownsAccessToken(token)
          || (
            !signedIn()
            && accessOpen(token)
            && request.resource.data.advocate_id == accessDocData(token).advocate_id
            && request.resource.data.case_id == accessDocData(token).case_number
            && request.resource.data.status == 'Client Submitted'
            && request.resource.data.requested_from_client == false
          );

        allow update, delete: if ownsAccessToken(token);
      }

      match /documents/{documentId} {
        allow read: if accessOpen(token) || ownsAccessToken(token);

        allow create: if ownsAccessToken(token)
          || (
            !signedIn()
            && accessOpen(token)
            && request.resource.data.advocate_id == accessDocData(token).advocate_id
            && request.resource.data.case_id == accessDocData(token).case_number
            && request.resource.data.uploaded_by_role == 'client'
          );

        allow update, delete: if ownsAccessToken(token);
      }

      match /comments/{commentId} {
        allow read: if accessOpen(token) || ownsAccessToken(token);

        allow create: if ownsAccessToken(token)
          || (
            !signedIn()
            && accessOpen(token)
            && request.resource.data.advocate_id == accessDocData(token).advocate_id
            && request.resource.data.case_id == accessDocData(token).case_number
            && request.resource.data.author_role == 'client'
          );

        allow update, delete: if ownsAccessToken(token);
      }
    }

    match /system_alerts/{alertId} {
      allow read, update, delete: if isAdmin() && resource.data.admin_id == request.auth.uid;
      allow create: if isAdmin() && request.resource.data.admin_id == request.auth.uid;
    }
  }
}
